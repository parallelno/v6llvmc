//===----------------------------------------------------------------------===//
//
// This file defines the V6C (Intel 8080) target-specific builtin function
// database. Users of this file must define the BUILTIN macro to make use of
// this information.
//
//===----------------------------------------------------------------------===//

// The format of this database matches clang/Basic/Builtins.def.

// I/O port access
BUILTIN(__builtin_v6c_in, "UcUc", "n")
BUILTIN(__builtin_v6c_out, "vUcUc", "n")

// Interrupt control
BUILTIN(__builtin_v6c_di, "v", "n")
BUILTIN(__builtin_v6c_ei, "v", "n")

// Processor control
BUILTIN(__builtin_v6c_hlt, "v", "n")
BUILTIN(__builtin_v6c_nop, "v", "n")

#undef BUILTIN
