# RUN: rm -rf %t && mkdir -p %t && split-file %s %t
# RUN: llc -mtriple=i8080-unknown-v6c -filetype=obj -o %t/main.o %t/main.ll
# RUN: llc -mtriple=i8080-unknown-v6c -filetype=obj -o %t/helper.o %t/helper.ll
# RUN: ld.lld -m elf32v6c -T %v6c_ld_script --defsym=_start=main \
# RUN:        -o %t/out.elf %t/main.o %t/helper.o
# RUN: llvm-readelf --file-headers --symbols %t/out.elf | FileCheck %s --check-prefix=ELF
# RUN: llvm-objcopy -O binary %t/out.elf %t/out.bin
# RUN: python -c "import sys; d=open(sys.argv[1],'rb').read(); print(len(d)); assert len(d)>0" %t/out.bin

## Verify ld.lld + the canonical V6C linker script produce a valid
## EM_V6C ELF, place the entry at 0x0100 (the script's `. = 0x0100`),
## and resolve cross-object call relocations.

# ELF: Class: {{.*}}ELF32
# ELF: Data: {{.*}}2's complement, little endian
# ELF: OS/ABI: {{.*}}Standalone App
# ELF: Type: {{.*}}EXEC (Executable file)
# ELF: Machine: {{.*}}8080
# ELF: Entry point address: {{.*}}0x100
## main is the entry (via --defsym=_start=main); ld.lld places it at 0x0100.
# ELF: 00000100 {{.*}} main
## helper is in a separate object; its address must be reachable from main
## via a R_V6C_16 absolute fixup.
# ELF: helper
## __stack_top is defined in the linker script at 0x0000.
# ELF: __stack_top

#--- main.ll
target datalayout = "e-p:16:8-i1:8-i8:8-i16:8-i32:8-i64:8-n8:16-S8"
target triple = "i8080-unknown-v6c"

declare i8 @helper(i8)

define i8 @main() section ".text._start" {
  %r = call i8 @helper(i8 7)
  ret i8 %r
}

#--- helper.ll
target datalayout = "e-p:16:8-i1:8-i8:8-i16:8-i32:8-i64:8-n8:16-S8"
target triple = "i8080-unknown-v6c"

define i8 @helper(i8 %x) {
  %r = add i8 %x, 1
  ret i8 %r
}
